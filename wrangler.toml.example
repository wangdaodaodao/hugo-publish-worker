name = "hugo-publish-worker"
main = "worker/index.js"
compatibility_date = "2024-03-12"

[vars]
DOMAIN = "your-blog-domain.com"
R2_DOMAIN = "your-files-domain.com"
GITHUB_OWNER = "your-github-username"
GITHUB_REPO = "your-github-repo"

# ！！！重要：请在 Cloudflare Dashboard 设置以下加密变量 (Secrets) ！！！
# GITHUB_TOKEN = "your_github_personal_access_token"
# JWT_SECRET = "your_random_jwt_secret"

# 如果需要草稿功能，请绑定 D1
# [[d1_databases]]
# binding = "DB"
# database_name = "your-d1-db-name"
# database_id = "your-d1-db-id"

# 如果需要图片上传功能，请绑定 R2
# [[r2_buckets]]
# binding = "R2"
# bucket_name = "your-r2-bucket-name"
